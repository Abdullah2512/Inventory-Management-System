# Supabase project credentials (Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Port the Express server listens on
PORT=5001

# Secret used to sign/verify JWTs — use a long random string in production
# e.g. generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# Allowed origin for CORS ("*" for local dev, your frontend URL in production)
CORS_ORIGIN=*
